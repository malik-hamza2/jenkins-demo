pipeline {
    agent any

    environment {
        DOCKER_USER = 'humzaaa'
        IMAGE_NAME = 'my-app'
    }

    stages {

        stage('Test (Container Based)') {
            steps {
                sh 'docker run --rm python:3.10-slim python -c "print(\\"Test Passed from Container\\")"'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_USER/$IMAGE_NAME:$BUILD_NUMBER .'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        sh 'echo $PASS | docker login -u $USER --password-stdin'
                    }

                    sh 'docker push $DOCKER_USER/$IMAGE_NAME:$BUILD_NUMBER'
                }
            }
        }

        stage('Deploy (Simulation)') {
            steps {
                sh '''
                docker stop my-container || true
                docker rm my-container || true
                docker run -d --name my-container -p 5000:5000 $DOCKER_USER/$IMAGE_NAME:$BUILD_NUMBER
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment successful'
        }
        failure {
            echo 'Pipeline failed'
        }
        always {
            echo 'Pipeline finished'
        }
    }
}
